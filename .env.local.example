# OpenAI API Key — required for AI context generation
OPENAI_API_KEY=sk-proj-...

# Optional: balldontlie API key for live game data fallback
# BALLDONTLIE_API_KEY=your-key-here

# Optional: Upstash Redis — persistent cache across serverless cold starts
# Get free credentials at: https://console.upstash.com → Create Database → REST API
# UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here
